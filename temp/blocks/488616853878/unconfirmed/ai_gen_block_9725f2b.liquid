{% doc %}
  @prompt
    blok do pokazu slajdow w hero, gdzie bede mial mozliwosc wyboru miedzy obrazkiem i ukladem na wersje mobilne a ukladem i obrazkiem na desktop
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slideshow__container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }

  .ai-hero-slideshow__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
    pointer-events: none;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-hero-slideshow__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-slideshow__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-slideshow__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    width: 90%;
    max-width: 800px;
    z-index: 2;
  }

  .ai-hero-slideshow__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slideshow__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }
  }

  .ai-hero-slideshow__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slideshow__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }
  }

  .ai-hero-slideshow__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slideshow__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-hero-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 3;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease;
    padding: 0;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-hero-slideshow__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_bg_color }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease;
  }

  .ai-hero-slideshow__nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg_color }};
  }

  .ai-hero-slideshow__nav-{{ ai_gen_id }}--prev {
    left: 24px;
  }

  .ai-hero-slideshow__nav-{{ ai_gen_id }}--next {
    right: 24px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slideshow__nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-hero-slideshow__nav-{{ ai_gen_id }}--prev {
      left: 12px;
    }

    .ai-hero-slideshow__nav-{{ ai_gen_id }}--next {
      right: 12px;
    }
  }

  .ai-hero-slideshow__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    z-index: 1;
  }
{% endstyle %}

<hero-slideshow-{{ ai_gen_id }}
  class="ai-hero-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-slideshow__container-{{ ai_gen_id }}">
    <div class="ai-hero-slideshow__slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
          assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign text_key = 'slide_' | append: i | append: '_text'
          assign button_text_key = 'slide_' | append: i | append: '_button_text'
          assign button_link_key = 'slide_' | append: i | append: '_button_link'
          assign desktop_layout_key = 'slide_' | append: i | append: '_desktop_layout'
          assign mobile_layout_key = 'slide_' | append: i | append: '_mobile_layout'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
          assign button_text = block.settings[button_text_key]
          assign button_link = block.settings[button_link_key]
          assign desktop_layout = block.settings[desktop_layout_key]
          assign mobile_layout = block.settings[mobile_layout_key]
        %}

        {% if slide_enabled %}
          <div
            class="ai-hero-slideshow__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
          >
            <div class="ai-hero-slideshow__image-wrapper-{{ ai_gen_id }}">
              {% if desktop_image or mobile_image %}
                <picture>
                  {% if mobile_image %}
                    <source
                      media="(max-width: 749px)"
                      srcset="{{ mobile_image | image_url: width: 1500 }}"
                    >
                  {% endif %}
                  {% if desktop_image %}
                    <img
                      src="{{ desktop_image | image_url: width: 2000 }}"
                      alt="{{ desktop_image.alt | escape }}"
                      class="ai-hero-slideshow__image-{{ ai_gen_id }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      width="{{ desktop_image.width }}"
                      height="{{ desktop_image.height }}"
                    >
                  {% elsif mobile_image %}
                    <img
                      src="{{ mobile_image | image_url: width: 1500 }}"
                      alt="{{ mobile_image.alt | escape }}"
                      class="ai-hero-slideshow__image-{{ ai_gen_id }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      width="{{ mobile_image.width }}"
                      height="{{ mobile_image.height }}"
                    >
                  {% endif %}
                </picture>
              {% else %}
                <div class="ai-hero-slideshow__image-placeholder-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_overlay %}
                <div class="ai-hero-slideshow__overlay-{{ ai_gen_id }}"></div>
              {% endif %}
            </div>

            <div class="ai-hero-slideshow__content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h2 class="ai-hero-slideshow__heading-{{ ai_gen_id }}">{{ heading }}</h2>
              {% endif %}

              {% if text != blank %}
                <div class="ai-hero-slideshow__text-{{ ai_gen_id }}">{{ text }}</div>
              {% endif %}

              {% if button_text != blank and button_link != blank %}
                <a
                  href="{{ button_link }}"
                  class="ai-hero-slideshow__button-{{ ai_gen_id }}"
                >
                  {{ button_text }}
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-hero-slideshow__nav-{{ ai_gen_id }} ai-hero-slideshow__nav-{{ ai_gen_id }}--prev"
        aria-label="Poprzedni slajd"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-hero-slideshow__nav-{{ ai_gen_id }} ai-hero-slideshow__nav-{{ ai_gen_id }}--next"
        aria-label="Następny slajd"
      >
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-hero-slideshow__controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button
              class="ai-hero-slideshow__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide-index="{{ forloop.index0 }}"
              aria-label="Przejdź do slajdu {{ forloop.index }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</hero-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-hero-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-hero-slideshow__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-hero-slideshow__nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-hero-slideshow__nav-{{ ai_gen_id }}--next');

        this.setupEventListeners();
        this.startAutoplay();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const autoplay = this.dataset.autoplay === 'true';
        const autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5;

        if (autoplay && this.slides.length > 1) {
          this.autoplayInterval = setInterval(() => {
            this.nextSlide();
          }, autoplaySpeed * 1000);
        }
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-slideshow-{{ ai_gen_id }}', HeroSlideshow{{ ai_gen_id }});
  })();
</script>

