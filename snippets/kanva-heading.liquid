{%- doc -%}
  Renders the Kanva three-tier heading block: label + heading + subtext.

  @param {string} label - Small uppercase label text (optional)
  @param {string} heading - Section heading text (optional)
  @param {string} subtext - Supporting body text (optional)
  @param {string} heading_level - HTML heading tag level, e.g. 'h2' (default: 'h2')
  @param {string} alignment - Text alignment: 'left', 'center', or 'right' (default: 'left')
{%- enddoc -%}

{%- liquid
  assign heading_tag = heading_level | default: 'h2'
-%}

<div class="kanva-heading" style="text-align: {{ alignment | default: 'left' }};">
  {% if label != blank %}<p class="kanva-heading__label">{{ label }}</p>{% endif %}
  {% if heading != blank %}<{{ heading_tag }} class="kanva-heading__title">{{ heading }}</{{ heading_tag }}>{% endif %}
  {% if subtext != blank %}<p class="kanva-heading__subtext">{{ subtext }}</p>{% endif %}
</div>

<style>
  .kanva-heading__label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--kanva-text-muted);
    margin-bottom: 16px;
  }

  .kanva-heading__title {
    font-size: clamp(32px, 4vw, 52px);
    font-weight: 400;
    line-height: 1.15;
    color: var(--kanva-text-primary);
    margin: 0 0 16px;
  }

  .kanva-heading__subtext {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--kanva-text-muted);
    max-width: 560px;
    margin: 0;
  }

  .kanva-heading[style*="text-align: center"] .kanva-heading__subtext {
    margin-left: auto;
    margin-right: auto;
  }
</style>
