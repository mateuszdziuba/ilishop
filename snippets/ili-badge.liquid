{%- doc -%}
  Renders a Ili pill-shaped badge/tag.

  @param {string} text - Badge text (required)
  @param {string} url - Optional URL; wraps badge in an <a> tag when provided
{%- enddoc -%}

{% if url != blank %}<a href="{{ url }}" class="ili-badge">{{ text }}</a>
{% else %}<span class="ili-badge">{{ text }}</span>{% endif %}

<style>
  .ili-badge {
    display: inline-block;
    background: var(--ili-badge-bg);
    color: var(--ili-text-primary);
    padding: 6px 14px;
    border-radius: var(--ili-pill-radius);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    line-height: 1;
  }
</style>
