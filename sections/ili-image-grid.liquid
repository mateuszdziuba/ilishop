<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style ili-image-grid"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="ili-image-grid"
>
  <div class="ili-image-grid__header">
    <div class="ili-image-grid__heading">
      {% render 'ili-heading', label: section.settings.label, heading: section.settings.heading %}
    </div>
    {%- if section.settings.link_text != blank -%}
      <a href="{{ section.settings.link_url }}" class="ili-image-grid__link">{{ section.settings.link_text }}</a>
    {%- endif -%}
  </div>

  <div class="ili-image-grid__grid">
    {%- comment -%} Each ili-image-grid-item block renders via blocks/ili-image-grid-item.liquid using: render 'ili-card' {%- endcomment -%}
    {%- content_for 'blocks' -%}
  </div>
</div>

{% stylesheet %}
  .ili-image-grid__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .ili-image-grid__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--ili-text-primary);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }

  .ili-image-grid__link:hover {
    opacity: 0.7;
  }

  .ili-image-grid__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 4px;
  }

  .ili-image-grid__item {
    aspect-ratio: 1 / 1;
  }

  @media screen and (max-width: 749px) {
    .ili-image-grid__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (max-width: 449px) {
    .ili-image-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ili Image Grid",
  "tag": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Follow us on Instagram"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "@ili"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "ili-image-grid-item",
      "name": "Image"
    }
  ],
  "presets": [
    {
      "name": "Ili Image Grid",
      "category": "Ili Editorial",
      "blocks": [
        { "type": "ili-image-grid-item" },
        { "type": "ili-image-grid-item" },
        { "type": "ili-image-grid-item" },
        { "type": "ili-image-grid-item" },
        { "type": "ili-image-grid-item" },
        { "type": "ili-image-grid-item" }
      ]
    }
  ]
}
{% endschema %}
