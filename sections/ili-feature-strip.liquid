{%- comment -%} sections/ili-feature-strip.liquid {%- endcomment -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style ili-feature-strip"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="ili-feature-strip"
>
  {%- if section.settings.label != blank or section.settings.heading != blank -%}
    {%- render 'ili-heading', label: section.settings.label, heading: section.settings.heading, alignment: 'center' -%}
  {%- endif -%}

  <div class="ili-feature-strip__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'ili-feature-item' -%}
        <div class="ili-feature-strip__item" {{ block.shopify_attributes }}>
          <div class="ili-feature-strip__icon">
            {%- case block.settings.icon -%}
              {%- when 'natural' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4-4-1.79-4-4z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'checkmark' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              {%- when 'shipping' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66L12 14"/><path d="M2 2s7 4 14 1c0 0-1 7-8 10"/></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endcase -%}
          </div>
          <div class="ili-feature-strip__title">{{ block.settings.title }}</div>
          <div class="ili-feature-strip__desc">{{ block.settings.description }}</div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .ili-feature-strip__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 32px;
    text-align: center;
    padding-top: 32px;
  }

  .ili-feature-strip__icon svg {
    width: 32px;
    height: 32px;
    stroke: var(--ili-text-primary);
    margin-bottom: 12px;
  }

  .ili-feature-strip__title {
    font-size: 16px;
    font-weight: 500;
    color: var(--ili-text-primary);
    margin-bottom: 4px;
  }

  .ili-feature-strip__desc {
    font-size: 14px;
    color: var(--ili-text-muted);
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ili-feature-strip__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ili Feature Strip",
  "tag": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "ili-feature-item",
      "name": "Feature item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "natural", "label": "Natural" },
            { "value": "shield", "label": "Shield" },
            { "value": "checkmark", "label": "Checkmark" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "star", "label": "Star" }
          ],
          "default": "natural"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Natural Formula"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "100% plant-based ingredients"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ili Feature Strip",
      "category": "Ili Editorial",
      "blocks": [
        {
          "type": "ili-feature-item",
          "settings": {
            "icon": "natural",
            "title": "Natural Formula",
            "description": "100% plant-based ingredients"
          }
        },
        {
          "type": "ili-feature-item",
          "settings": {
            "icon": "shield",
            "title": "Cruelty-Free",
            "description": "Never tested on animals"
          }
        },
        {
          "type": "ili-feature-item",
          "settings": {
            "icon": "checkmark",
            "title": "Expert Approved",
            "description": "Dermatologist tested & approved"
          }
        },
        {
          "type": "ili-feature-item",
          "settings": {
            "icon": "shipping",
            "title": "Free Shipping",
            "description": "On orders over \u20ac40"
          }
        }
      ]
    }
  ]
}
{% endschema %}
