{%- comment -%} sections/ili-testimonial.liquid {%- endcomment -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style ili-testimonial"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="ili-testimonial"
>
  {%- if section.settings.label != blank or section.settings.heading != blank -%}
    {%- render 'ili-heading', label: section.settings.label, heading: section.settings.heading, alignment: 'center' -%}
  {%- endif -%}

  <div class="ili-testimonial__content">
    {%- for block in section.blocks -%}
      {%- if block.type == 'ili-testimonial-quote' -%}
        <div class="ili-testimonial__quote-block" {{ block.shopify_attributes }}>
          <div class="ili-testimonial__stars" aria-label="{{ block.settings.stars }} out of 5 stars">
            {%- for i in (1..block.settings.stars) -%}&#9733;{%- endfor -%}
          </div>
          <blockquote class="ili-testimonial__quote">
            {{ block.settings.quote }}
          </blockquote>
          {%- if block.settings.author != blank -%}
            <cite class="ili-testimonial__author">{{ block.settings.author }}</cite>
          {%- endif -%}
          {%- if block.settings.rating_summary != blank -%}
            <div class="ili-testimonial__rating-summary">{{ block.settings.rating_summary }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .ili-testimonial__content {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .ili-testimonial__stars {
    font-size: 24px;
    color: var(--ili-sage);
    margin-bottom: 24px;
    letter-spacing: 4px;
  }

  .ili-testimonial__quote {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 400;
    line-height: 1.5;
    color: var(--ili-text-primary);
    font-style: normal;
    margin: 0 0 24px;
    padding: 0;
    border: 0;
  }

  .ili-testimonial__author {
    font-size: 14px;
    font-weight: 500;
    color: var(--ili-text-primary);
    display: block;
    margin-bottom: 8px;
    font-style: normal;
  }

  .ili-testimonial__rating-summary {
    font-size: 13px;
    color: var(--ili-text-muted);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Ili Testimonial",
  "tag": "section",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "ili-testimonial-quote",
      "name": "Quote",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote text"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name & title"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "rating_summary",
          "label": "Rating summary",
          "default": "4.7 / 5 \u00b7 1,109 reviews"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ili Testimonial",
      "category": "Ili Editorial",
      "blocks": [
        {
          "type": "ili-testimonial-quote",
          "settings": {
            "quote": "I\u2019ve tried dozens of skincare brands and nothing has transformed my skin like Ili. My skin is clearer, softer, and genuinely glowing.",
            "author": "Jennifer K., Verified Buyer",
            "stars": 5,
            "rating_summary": "4.7 / 5 \u00b7 1,109 reviews"
          }
        }
      ]
    }
  ]
}
{% endschema %}
